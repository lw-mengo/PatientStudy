<ui:FluentWindow
  x:Class="PatientStudy.Views.Windows.LoginWindow"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:local="clr-namespace:PatientStudy.Views.Windows"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
  Title="PatientStudy - Sign in"
  Width="500"
  Height="360"
  MinWidth="500"
  MinHeight="360"
  ResizeMode="NoResize"
  WindowStartupLocation="CenterScreen"
  mc:Ignorable="d"
  ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
  ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
>
  <Grid Margin="20">
    <Border
      Padding="24"
      HorizontalAlignment="Center"
      VerticalAlignment="Center"
      Background="{DynamicResource ControlFillColorSecondaryBrush}"
      BorderBrush="{DynamicResource ControlStrokeColorSecondaryBrush}"
      BorderThickness="1"
      CornerRadius="12"
    >
      <Grid Width="360">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
          <TextBlock FontSize="22" FontWeight="SemiBold" Text="PatientStudy" />
          <TextBlock Margin="0,4,0,0" FontSize="14" Opacity="0.75" Text="Sign in to continue" />
        </StackPanel>

        <StackPanel Grid.Row="1">
          <TextBlock Margin="0,0,0,6" FontWeight="SemiBold" Text="Username" />
          <TextBox
            Height="34"
            Padding="10,0"
            Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
          />

          <TextBlock Margin="0,14,0,6" FontWeight="SemiBold" Text="Password" />
          <PasswordBox x:Name="PasswordBox" Height="34" Padding="10,0" />

          <TextBlock Margin="0,8,0,0" Foreground="IndianRed" Text="{Binding ErrorMessage}" />
        </StackPanel>

        <StackPanel
          Grid.Row="2"
          Margin="0,20,0,0"
          HorizontalAlignment="Right"
          Orientation="Horizontal"
        >
          <ui:Button Width="96" Margin="0,0,10,0" Command="{Binding CancelCommand}" Content="Cancel" />
          <ui:Button Width="96" Command="{Binding LoginCommand}" Content="Login" />
        </StackPanel>
      </Grid>
    </Border>
  </Grid>
</ui:FluentWindow>
